# FrigoFute V2 - Environment Variables Template
# Copy this file to .env.dev, .env.staging, or .env.prod and fill in the values

# Environment
ENVIRONMENT=dev

# API Configuration
API_BASE_URL=https://dev-api.frigofute.com

# Firebase (DO NOT commit actual values)
# Get these from Firebase Console: https://console.firebase.google.com/
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_API_KEY=your-api-key
FIREBASE_APP_ID=your-app-id

# Google Cloud APIs
GOOGLE_VISION_API_KEY=your-vision-api-key
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_MAPS_API_KEY=your-maps-api-key

# Feature Flags
ENABLE_ANALYTICS=false
ENABLE_CRASHLYTICS=false

# AI/ML Configuration
GEMINI_MODEL_VERSION=gemini-pro-dev
OCR_CONFIDENCE_THRESHOLD=0.85

# Debug Settings
ENABLE_DEBUG_LOGGING=true
LOG_LEVEL=debug
