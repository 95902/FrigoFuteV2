# FrigoFute V2 - Environment Configuration Example
# Story 0.10: Security Foundation and API Keys Management
#
# IMPORTANT: This is an EXAMPLE file - DO NOT put real values here!
# Copy this file to .env.dev, .env.staging, or .env.prod and fill in real values.
# All .env.* files are gitignored for security.

# API Base URL (Cloud Functions endpoint)
API_BASE_URL=https://us-central1-your-project-id.cloudfunctions.net

# Firebase Project ID
FIREBASE_PROJECT_ID=your-firebase-project-id

# Analytics Configuration
ENABLE_ANALYTICS=true

# Gemini AI Model Version
GEMINI_MODEL_VERSION=2.5-flash

# Environment Name
ENVIRONMENT=development

# Feature Flags (optional - Remote Config takes precedence)
ENABLE_OFFLINE_MODE=true
ENABLE_NUTRITION_TRACKING=false
ENABLE_AI_COACH=false
